# =========================================================
# Redmi AX5 (IPQ60xx) - LiBwrt/openwrt-6.x main-nss
# 单机型模式：用 CONFIG_TARGET_PROFILE 选设备
# =========================================================

# --- 1) 目标平台 ---
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
# CONFIG_TARGET_MULTI_PROFILE is not set
CONFIG_TARGET_PROFILE="DEVICE_redmi_ax5"
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# --- 2) 内存档位（AX5 必须 256）---
CONFIG_ATH11K_MEM_PROFILE_256M=y
# CONFIG_ATH11K_MEM_PROFILE_512M is not set
# CONFIG_ATH11K_MEM_PROFILE_1G is not set
CONFIG_IPQ_MEM_PROFILE_256=y
# CONFIG_IPQ_MEM_PROFILE_512 is not set
# CONFIG_IPQ_MEM_PROFILE_1024 is not set
CONFIG_KERNEL_IPQ_MEM_PROFILE=256

# --- 3) NSS 核心 ---
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_qca-nss-ecm-standard=y
# CONFIG_PACKAGE_qca-nss-ecm-noload is not set

# --- 4) LuCI 与中文 ---
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
# CONFIG_PACKAGE_luci-theme-argon is not set

# --- 5) PassWall + Sing-Box ---
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y
CONFIG_PACKAGE_sing-box=y

# 精简 PassWall 冗余
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin is not set
# CONFIG_PACKAGE_v2ray-plugin is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs is not set
# CONFIG_PACKAGE_simple-obfs-client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy is not set
# CONFIG_PACKAGE_haproxy is not set

# --- 6) 必备插件 ---
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_igmpproxy=y
CONFIG_PACKAGE_udpxy=y
CONFIG_PACKAGE_luci-app-udpxy=y
CONFIG_PACKAGE_luci-i18n-udpxy-zh-cn=y

# --- 7) 运行内存优化 ---
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y
# CONFIG_PACKAGE_wpad-openssl is not set
# CONFIG_PACKAGE_wpad-mesh-openssl is not set

# --- 8) 避免依赖冲突 ---
# CONFIG_PACKAGE_fwupd-libs is not set

# --- 9) 精简 USB/FS ---
# CONFIG_USB_SUPPORT is not set
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb-dwc3 is not set
# CONFIG_PACKAGE_kmod-usb-dwc3-qcom is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-usb-roles is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_kmod-usb-storage-extras is not set
# CONFIG_PACKAGE_kmod-usb-storage-uas is not set
# CONFIG_PACKAGE_kmod-fs-ext4 is not set
# CONFIG_PACKAGE_kmod-fs-f2fs is not set
# CONFIG_PACKAGE_kmod-fs-ntfs3 is not set
# CONFIG_PACKAGE_kmod-fs-vfat is not set
# CONFIG_PACKAGE_kmod-fs-exfat is not set
# CONFIG_PACKAGE_e2fsprogs is not set
# CONFIG_PACKAGE_f2fs-tools is not set
# CONFIG_PACKAGE_f2fsck is not set
# CONFIG_PACKAGE_mkf2fs is not set
