# --- 强制指定硬件与固件格式 ---
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set
# ------------------------------

# 下面继续保留您之前的插件配置
CONFIG_PACKAGE_luci-app-passwall=y
...

# 核心插件 - PassWall 换装 Sing-box
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y
# 显式勾选 Sing-box 核心
CONFIG_PACKAGE_sing-box=y

# 核心插件 - 其他必需品
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y

# IPTV 与 多播支持
CONFIG_PACKAGE_igmpproxy=y
CONFIG_PACKAGE_udpxy=y
CONFIG_PACKAGE_luci-app-udpxy=y

# 基础显示与中文
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-theme-argon=y

# --- 极致瘦身：彻底移除不必要项 ---
# 1. 移除 Xray (换了 Sing-box 就不再需要它)
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray is not set

# 2. 移除所有存储、文件系统与 USB 驱动 (固件瘦身大户)
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_kmod-fs-ntfs3 is not set
# CONFIG_PACKAGE_kmod-fs-vfat is not set
# CONFIG_PACKAGE_kmod-fs-f2fs is not set
# CONFIG_PACKAGE_kmod-fs-ext4 is not set

# 3. 移除 Docker 与 其它重型应用
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_luci-app-homeproxy is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set

# 4. 保留网络加速 (NSS) - AX5 必留
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
